{
  "manifest_version": 3,
  "name": "TLDR free",
  "version": "0.1.0",
  "description": "Local summaries and Q&A for web pages and YouTube videos. Open source, no API keys, nothing leaves your machine.",
  "minimum_chrome_version": "116",
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "cookies",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.youtube.com/*",
    "https://www.youtube.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Summarize this page"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "options_page": "src/options/index.html",
  "web_accessible_resources": [
    {
      "resources": ["src/library/index.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
